        <mxCell id="flow2" value="2. CDN checks cache, serves if available (cache hit)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
