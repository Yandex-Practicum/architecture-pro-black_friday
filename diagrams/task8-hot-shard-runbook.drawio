<mxfile host="app.diagrams.net">
  <diagram name="hot-shard-school-check" id="task8-school-runbook">
    <mxGraphModel dx="3235" dy="2028" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1160" pageHeight="1900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="start" parent="1" style="ellipse;whiteSpace=wrap;html=1;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="Начало" vertex="1">
          <mxGeometry height="60" width="220" x="380" y="40" as="geometry" />
        </mxCell>
        <mxCell id="collect" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;Снять базовые метрики&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Стенд: mongo-sharding-repl&lt;br&gt;mongos-router:27020 · shard1-1/shard2-1:27019&lt;br&gt;sh.status(true), getShardDistribution(), mongostat, $collStats, docker stats, balancer status&lt;/font&gt;" vertex="1">
          <mxGeometry height="88" width="400" x="290" y="130" as="geometry" />
        </mxCell>
        <mxCell id="incident" parent="1" style="shape=note;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;size=12;" value="&lt;b&gt;Пример инцидента&lt;/b&gt;&lt;br&gt;70% запросов: категория «Электроника».&lt;br&gt;&lt;br&gt;Ищи: scatter-gather, legacy shard-key category, hot SKU при $inc stock." vertex="1">
          <mxGeometry height="130" width="220" x="720" y="130" as="geometry" />
        </mxCell>
        <mxCell id="check1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fontSize=11;fillColor=#ffffff;strokeColor=#6c8ebf;" value="&lt;b&gt;Проверка 1. Chunks Distribution&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Команда: getShardDistribution(); config.chunks.aggregate(...)&lt;br&gt;Тест: chunks/size между rs-shard1 и rs-shard2 отличаются &amp;lt; 10%, jumbo = 0&lt;/font&gt;" vertex="1">
          <mxGeometry height="74" width="380" x="300" y="280" as="geometry" />
        </mxCell>
        <mxCell id="d1" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Тест 1&lt;br&gt;пройден?" vertex="1">
          <mxGeometry height="90" width="140" x="420" y="380" as="geometry" />
        </mxCell>
        <mxCell id="cause1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Нет: возможные причины&lt;/b&gt;&lt;br&gt;jumbo chunk · balancer выключен · неудачный shard-key · chunks застряли на одном шарде&lt;br&gt;&lt;br&gt;&lt;b&gt;Как исправить&lt;/b&gt;&lt;br&gt;sh.startBalancer() · split chunk · moveRange · reshard" vertex="1">
          <mxGeometry height="120" width="340" x="710" y="365" as="geometry" />
        </mxCell>
        <mxCell id="check2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fontSize=11;fillColor=#ffffff;strokeColor=#6c8ebf;" value="&lt;b&gt;Проверка 2. Query / Load per Shard&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Команда: mongostat shard1-1/shard2-1; db.serverStatus().opcounters; curl :8080/&lt;br&gt;Тест: ops/s на шардах отличаются ≤ 20% от среднего&lt;/font&gt;" vertex="1">
          <mxGeometry height="78" width="380" x="300" y="520" as="geometry" />
        </mxCell>
        <mxCell id="d2" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Тест 2&lt;br&gt;пройден?" vertex="1">
          <mxGeometry height="90" width="140" x="420" y="625" as="geometry" />
        </mxCell>
        <mxCell id="cause2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Нет: возможные причины&lt;/b&gt;&lt;br&gt;scatter-gather · hot category «Электроника» · hot SKU · запрос без shard-key&lt;br&gt;&lt;br&gt;&lt;b&gt;Как исправить&lt;/b&gt;&lt;br&gt;explain() · индекс под фильтр · targeted query · reshard на { _id: &amp;quot;hashed&amp;quot; }" vertex="1">
          <mxGeometry height="128" width="340" x="710" y="606" as="geometry" />
        </mxCell>
        <mxCell id="check3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fontSize=11;fillColor=#ffffff;strokeColor=#6c8ebf;" value="&lt;b&gt;Проверка 3. Read / Write Latency p99&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Команда: $collStats latencyStats; profiler slowms=100; currentOp&lt;br&gt;Тест: p99 ≤ 100 ms и не больше 2× других шардов&lt;/font&gt;" vertex="1">
          <mxGeometry height="78" width="380" x="300" y="765" as="geometry" />
        </mxCell>
        <mxCell id="d3" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Тест 3&lt;br&gt;пройден?" vertex="1">
          <mxGeometry height="90" width="140" x="420" y="870" as="geometry" />
        </mxCell>
        <mxCell id="cause3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Нет: возможные причины&lt;/b&gt;&lt;br&gt;COLLSCAN · нет индекса · блокировки · медленный диск · лишний scatter-gather&lt;br&gt;&lt;br&gt;&lt;b&gt;Как исправить&lt;/b&gt;&lt;br&gt;создать индекс · изменить read-model · убрать запросы без shard-key" vertex="1">
          <mxGeometry height="128" width="340" x="700" y="851" as="geometry" />
        </mxCell>
        <mxCell id="check4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fontSize=11;fillColor=#ffffff;strokeColor=#6c8ebf;" value="&lt;b&gt;Проверка 4. CPU / IOPS&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Команда: docker stats shard1-1 shard2-1&lt;br&gt;Тест: CPU и IOPS &amp;lt; 70% в пике, нет перекоса только на одном Primary&lt;/font&gt;" vertex="1">
          <mxGeometry height="78" width="380" x="300" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="d4" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Тест 4&lt;br&gt;пройден?" vertex="1">
          <mxGeometry height="90" width="140" x="420" y="1115" as="geometry" />
        </mxCell>
        <mxCell id="cause4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fontSize=10;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Нет: возможные причины&lt;/b&gt;&lt;br&gt;CPU saturation · IOPS saturation · replication lag · тяжёлые запросы на Primary&lt;br&gt;&lt;br&gt;&lt;b&gt;Как исправить&lt;/b&gt;&lt;br&gt;масштабировать shard · разгрузить запросы · проверить диск · проверить лаг реплик" vertex="1">
          <mxGeometry height="128" width="340" x="700" y="1096" as="geometry" />
        </mxCell>
        <mxCell id="check5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fontSize=11;fillColor=#ffffff;strokeColor=#6c8ebf;" value="&lt;b&gt;Проверка 5. Balancer State&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Команда: sh.getBalancerState(); sh.getBalancerStatus()&lt;br&gt;Тест: State = true, inBalancerRound = false, нет ошибок миграций&lt;/font&gt;" vertex="1">
          <mxGeometry height="78" width="380" x="300" y="1255" as="geometry" />
        </mxCell>
        <mxCell id="d5" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="Тест 5&lt;br&gt;пройден?" vertex="1">
